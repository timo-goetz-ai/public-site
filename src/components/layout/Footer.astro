---
const links = [
  { href: '/projects', label: 'Projekte' },
  { href: '/about',    label: 'Uber mich' },
  { href: '/impressum', label: 'Impressum' },
];
---

<footer style="border-top: 1px solid var(--border); background: var(--bg-2);">
  <div class="mx-auto max-w-5xl px-6 py-8 flex items-center justify-between flex-wrap gap-4">
    <div class="flex items-center gap-3">
      <span style="background: var(--accent-2); width: 6px; height: 6px; border-radius: 50; display: inline-block;" class="rounded-full"></span>
      <p style="color: var(--subtle);" class="text-xs">
        &copy; {new Date().getFullYear()} Timo Goetz
      </p>
    </div>
    <nav class="flex gap-6">
      {links.map(({ href, label }) => (
        <a
          href={href}
          style="color: var(--subtle);"
          class="text-xs hover:text-[var(--text)] transition-colors"
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</footer>
