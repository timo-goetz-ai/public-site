---
const navLinks = [
  { href: '/projects', label: 'Projekte' },
  { href: '/about', label: 'Über mich' },
  { href: '/contact', label: 'Kontakt' },
  { href: '/impressum', label: 'Impressum' },
  { href: '/datenschutz', label: 'Datenschutz' },
];
---

<footer style="border-top: 1px solid var(--border); background: var(--bg-card);">
  <div class="mx-auto max-w-5xl px-6 py-12">
    <div class="grid gap-8 sm:grid-cols-3">

      <!-- Col 1: Brand -->
      <div>
        <p class="text-sm font-semibold mb-2" style="color: var(--text);">Timo Goetz</p>
        <p class="text-xs leading-relaxed" style="color: var(--subtle);">
          Weniger Verderb.<br />
          Bessere Auslastung.<br />
          Mehr Marge.
        </p>
      </div>

      <!-- Col 2: Navigation -->
      <nav>
        <p class="text-xs font-medium uppercase tracking-widest mb-3" style="color: var(--muted);">Navigation</p>
        <ul class="flex flex-col gap-2">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                style="color: var(--subtle);"
                class="text-xs hover:text-[var(--text)] transition-colors"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Col 3: Contact -->
      <div>
        <p class="text-xs font-medium uppercase tracking-widest mb-3" style="color: var(--muted);">Kontakt</p>
        <a
          href="mailto:timo@timo-goetz-ai.de"
          class="block text-xs mb-2 hover:text-[var(--text)] transition-colors"
          style="color: var(--subtle);"
        >
          timo@timo-goetz-ai.de
        </a>
        <a
          href="https://www.linkedin.com/in/timo-goetz"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs hover:text-[var(--text)] transition-colors"
          style="color: var(--subtle);"
        >
          LinkedIn
        </a>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 flex items-center justify-between flex-wrap gap-4" style="border-top: 1px solid var(--border);">
      <p style="color: var(--subtle);" class="text-xs">
        &copy; {new Date().getFullYear()} Timo Goetz — Forecasting-Spezialist · Perishable Operations · DACH
      </p>
    </div>
  </div>
</footer>
