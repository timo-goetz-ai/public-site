---
import MagneticButton from '@/components/ui/MagneticButton.astro';
import MagneticCard from '@/components/ui/MagneticCard.astro';
import AnimatedBackground from '@/components/ui/AnimatedBackground.astro';
---

<section class="min-h-screen flex items-center relative overflow-hidden bg-[var(--bg)]">
  <div
    class="absolute inset-0"
    style="background-image: radial-gradient(rgba(15,23,42,0.06) 1px, transparent 1px); background-size: 32px 32px;"
  ></div>
  <AnimatedBackground variant="dark" />

  <div class="mx-auto max-w-5xl px-6 w-full pt-24 pb-20 relative z-10">
    <div class="grid md:grid-cols-5 gap-16 items-center">

      <div class="md:col-span-3">
        <div class="flex items-center gap-3 mb-10">
          <span style="background: var(--accent-2); width: 8px; height: 8px;" class="rounded-full inline-block animate-pulse"></span>
          <p style="color: var(--accent); letter-spacing: 0.12em;" class="text-xs uppercase font-medium">
            System Online
          </p>
          <span style="color: var(--subtle);" class="text-xs">|</span>
          <p style="color: var(--muted); letter-spacing: 0.12em;" class="text-xs uppercase">
            KI-Beauftragter &middot; DEKRA zertifiziert
          </p>
        </div>

        <h1
          style="color: var(--text); line-height: 1.08;"
          class="text-5xl md:text-7xl font-semibold tracking-tight mb-8"
        >
          KI-Beauftragter<br />
          mit Fuehrungs-<br />
          <span style="color: var(--accent-2);">erfahrung.</span>
        </h1>

        <p style="color: var(--muted);" class="text-lg leading-relaxed max-w-lg mb-10">
          Ich baue Automatisierungen, die funktionieren &mdash;
          weil ich die Prozesse dahinter kenne.
        </p>

        <div class="flex flex-wrap items-center gap-4">
          <MagneticButton href="/projects" text="Projekte ansehen →" variant="primary" />
          <MagneticButton href="/about" text="Über mich" variant="ghost" />
        </div>
      </div>

      <div class="hidden md:block md:col-span-2 space-y-5">
        <div class="rounded-xl overflow-hidden border border-[var(--border)] shadow-sm bg-[var(--bg-2)]">
          <img
            src="/timo-goetz.png"
            alt="Timo Goetz"
            width="440"
            height="520"
            class="w-full h-auto object-cover object-top"
            loading="eager"
          />
        </div>
        <div style="background: var(--bg-card); border: 1px solid var(--border);" class="rounded-xl p-6 shadow-sm">
          <p style="color: var(--accent); letter-spacing: 0.1em;" class="text-xs uppercase font-semibold mb-5">Stack &amp; Skills</p>

          <div class="space-y-3">
            {[
              { label: 'Python & TypeScript', status: 'active' },
              { label: 'n8n Workflows', status: 'active' },
              { label: 'MCP Server', status: 'active' },
              { label: 'Coolify / Hetzner', status: 'active' },
              { label: 'Prompt Engineering', status: 'active' },
            ].map(({ label, status }) => (
              <div class="flex items-center justify-between">
                <span style="color: var(--text);" class="text-sm">{label}</span>
                <div class="flex items-center gap-2">
                  <span style="background: var(--success); width: 6px; height: 6px;" class="rounded-full inline-block"></span>
                  <span style="color: var(--success);" class="text-xs font-mono">{status}</span>
                </div>
              </div>
            ))}
          </div>

          <div style="border-top: 1px solid var(--border);" class="mt-5 pt-5">
            <div class="flex items-center justify-between">
              <span style="color: var(--subtle);" class="text-xs">Abschluss</span>
              <span style="color: var(--accent-2);" class="text-sm font-semibold font-mono">1,0</span>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div style="border-top: 1px solid var(--border);" class="flex flex-wrap gap-4 mt-20 pt-8">
      {[
        { label: 'Projekte',   value: '5+',  variant: 'dark' as const },
        { label: 'MCP Server', value: '15',  variant: 'dark' as const },
        { label: 'Workflows',  value: '20+', variant: 'dark' as const },
        { label: 'Uptime',     value: '47d', variant: 'dark' as const },
      ].map(({ label, value, variant }) => (
        <MagneticCard {variant} class="px-6 py-4 text-center min-w-[90px]">
          <p style="color: var(--accent-2);" class="text-2xl font-semibold font-mono">{value}</p>
          <p style="color: var(--subtle);" class="text-xs mt-1">{label}</p>
        </MagneticCard>
      ))}
    </div>
  </div>
</section>
