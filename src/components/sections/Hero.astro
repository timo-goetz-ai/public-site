---
import MagneticButton from '../ui/MagneticButton.astro';
import { Image } from 'astro:assets';
import heroBg from '../../assets/hero-bg.jpg';
---

<section class="hero-section relative flex min-h-screen items-center overflow-hidden">
<style>
  .hero-section {
    background:
      radial-gradient(ellipse 80% 50% at 20% 30%, rgba(45, 106, 79, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 75% 70%, rgba(200, 121, 65, 0.05) 0%, transparent 50%),
      var(--bg);
  }
</style>
  <div class="mx-auto w-full max-w-6xl px-6 pb-20 pt-28">
    <div class="grid items-start gap-16 lg:grid-cols-[minmax(0,1.15fr)_420px]">
      <div class="max-w-3xl">
        <p style="color: var(--muted); letter-spacing: 0.14em;" class="mb-8 text-xs font-medium uppercase">
          Forecasting-Spezialist · Perishable Operations · DACH
        </p>

        <h1 style="color: var(--text); line-height: 1.02;" class="mb-8 text-5xl font-semibold tracking-tight md:text-6xl">
          Weniger Verderb.<br />
          Bessere Auslastung.<br />
          Mehr Marge.
        </h1>

        <p style="color: var(--muted);" class="mb-8 max-w-xl text-lg leading-relaxed">
          ML-Prognose-Systeme für Fresh-Food-Retail,
          Lebensmittelautomaten und Gastronomie.
        </p>

        <!-- Case Study Pill -->
        <div
          class="mb-10 inline-block rounded-lg px-4 py-3 text-sm"
          style="border: 1px solid var(--border); background: var(--bg-card);"
        >
          <span class="font-mono text-xs uppercase tracking-widest" style="color: var(--subtle);">Case Study</span>
          <p class="mt-1 text-sm" style="color: var(--text);">
            DACH-Betreiber · Verderb messbar reduziert · ROI &lt;12 Monate
          </p>
        </div>

        <div class="flex flex-wrap items-center gap-4">
          <MagneticButton text="Opportunity Scan — 2.500 €" href="#services" variant="primary" />
          <MagneticButton text="Kostenloses 30-Min Discovery" href="#contact" variant="ghost-light" />
        </div>
      </div>

      <div class="space-y-4">
        <div class="overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--bg-card)]">
          <Image
            src={heroBg}
            width={420}
            height={520}
            format="webp"
            quality={82}
            alt="Frische Kräuter, Gemüse und Produkte auf warmer Leinenoberfläche — natürliches Licht, editoriale Qualität"
            class="h-auto w-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <div class="grid grid-cols-2 gap-3">
          {[
            { label: 'Vertikal', value: '7' },
            { label: 'Früheste Phase', value: 'Scan' },
            { label: 'DACH', value: '✓' },
            { label: 'DEKRA', value: 'Zert.' },
          ].map(({ label, value }) => (
            <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] px-4 py-4">
              <p style="color: var(--text);" class="text-xl font-semibold">{value}</p>
              <p style="color: var(--subtle);" class="mt-1 text-xs uppercase tracking-[0.08em]">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
